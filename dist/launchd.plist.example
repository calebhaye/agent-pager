<?xml version="1.0" encoding="UTF-8"?>
<!--
  agent-pager daemon for macOS (launchd).
  Install:
    cp dist/launchd.plist.example ~/Library/LaunchAgents/com.agent-pager.plist
    # edit the two paths below, then:
    launchctl load ~/Library/LaunchAgents/com.agent-pager.plist
  Config (repo/issue/allowlist/owner) is read from ~/.agent-pager/config.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.agent-pager</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>/ABSOLUTE/PATH/TO/agent-pager</string>
    <string>daemon</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/agent-pager.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/agent-pager.log</string>
</dict>
</plist>
